{
  "name": "bh-common-modules",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "watch": "babel --watch src ---out-dir dist --extensions '.ts,.tsx'",
    "build": "babel src --out-dir dist --extensions '.ts,.tsx'",
    "tsc": "tsc",
    "prepublishOnly": "npm run build && cp -r ./dist/* . && rm -rf ./dist",
    "postpublish": "git clean -fd",
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "test": "echo 'no need to test bh-common-modules'",
    "dep-test": "npm run lint && npm run lint"
  },
  "dependencies": {
    "twrnc": "latest",
    "react-native": "0.66.4",
    "moment": "^2.29.3",
    "react-native-track-player": "2.1.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.178",
    "@types/react": "^17.0.13",
    "@types/react-dom": "^17.0.8",
    "@types/react-native": "^0.66.4",
    "lodash": "4.17.21",
    "react": "17.0.2",
    "react-native": "0.66.4",
    "scripts": "*",
    "tsup": "^5.10.1",
    "typescript": "^4.2.4"
  }
}
